# Bluesky Credentials (Required)
BLUESKY_IDENT=your.handle.here
BLUESKY_PASS=your-app-password-here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Listener Configuration
POLLING_FREQ_SECONDS=300

# How often the listener re-fetches manufacturer product pages to refresh the
# JSON-LD price for posts with a `product_url` override (see README "Pricing
# Overrides"). Default: 21600 = 6h. Lower if you want fresher prices, but be
# kind to the manufacturer sites — most update at most daily.
# PRICE_REFRESH_FREQ_SECONDS=21600

# Hashtag to Monitor (include the # prefix)
HASHTAG_TO_WATCH=#YourTag

# Handles to Watch (optional, comma-separated list of Bluesky handles)
# If set, only posts from these handles will be collected
# If not set or empty, posts from ANY handle with the hashtag will be collected
# HANDLES_TO_WATCH=handle1.bsky.social,handle2.bsky.social,handle3.bsky.social

# Site Title (optional, human-readable wordmark for the gallery masthead)
# When unset, the gallery falls back to displaying the hashtag itself.
# SITE_TITLE=Ryan's Watches

# Frontend Port
PORT=3000

# eBay Browse API credentials — powers the per-post "Recent listings" widget.
# Sign up at https://developer.ebay.com/ → create a production keyset → grab
# App ID + Cert ID. EBAY_ENV defaults to 'sandbox' (safe but synthetic data);
# flip to 'production' once you've confirmed the widget renders.
# EBAY_CLIENT_ID=YOUR_APP_ID
# EBAY_CLIENT_SECRET=YOUR_CERT_ID
# EBAY_ENV=sandbox
